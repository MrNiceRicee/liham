{
	"name": "@mrnicericee/liham",
	"version": "1.1.0",
	"description": "Terminal markdown previewer with split-pane view, search, TOC, math, mermaid, and media support",
	"type": "module",
	"license": "MIT",
	"author": "Joshua Santos",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mrnicericee/liham.git"
	},
	"homepage": "https://github.com/mrnicericee/liham",
	"bugs": "https://github.com/mrnicericee/liham/issues",
	"keywords": [
		"markdown",
		"terminal",
		"previewer",
		"tui",
		"cli",
		"bun"
	],
	"engines": {
		"bun": ">=1.1.0"
	},
	"bin": {
		"liham": "src/cli/index.ts"
	},
	"files": [
		"src/",
		"!src/**/*.test.ts",
		"!src/**/test-utils.ts"
	],
	"scripts": {
		"dev": "bun run src/cli/index.ts",
		"lint": "eslint src/",
		"format": "biome format --write",
		"format:check": "biome format",
		"typecheck": "tsc --noEmit",
		"check": "bun run typecheck && bun run lint && bun run format:check",
		"test": "bun test",
		"prepublishOnly": "bun run check && bun test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@eslint/js": "^10.0.1",
		"@types/bun": "latest",
		"@types/react": "^19.2.14",
		"eslint": "^10.0.2",
		"eslint-plugin-perfectionist": "^5.6.0",
		"eslint-plugin-sonarjs": "^4.0.0",
		"jiti": "^2.6.1",
		"typescript-eslint": "^8.56.1"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@opentui/core": "^0.1.86",
		"@opentui/react": "^0.1.86",
		"beautiful-mermaid": "^1.1.3",
		"rehype-highlight": "^7.0.2",
		"remark-gfm": "^4.0.1",
		"remark-math": "^6.0.0",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"unicodeit": "^0.7.5",
		"unified": "^11.0.5"
	},
	"optionalDependencies": {
		"sharp": "^0.34.5"
	}
}
