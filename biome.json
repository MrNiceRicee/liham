{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "all",
			"semicolons": "asNeeded"
		}
	},
	"linter": {
		"enabled": false
	},
	"files": {
		"includes": ["**", "!**/.claude/**", "!**/dist/**", "!**/node_modules/**"]
	}
}
